{
  "skill": "cc-context-monitor",
  "description": "Behavioral eval cases for the cc-context-monitor statusline wrapper. Each case pipes a JSON blob on stdin and asserts the wrapper output contains the expected ctx/5h/7d dot-bar segments, the expected color band, and the expected fallback text when fields or ccusage are missing.",
  "cases": [
    {
      "name": "zero-percent-all-green",
      "type": "positive",
      "description": "Fresh session: 0% across ctx, 5h, 7d. Every bar is fully empty and color is green.",
      "stub_ccusage_output": "",
      "stub_ccusage_exit": 0,
      "stdin_json": {
        "session_id": "eval-0pct",
        "transcript_path": "EVAL_TRANSCRIPT",
        "cwd": "/tmp",
        "model": { "id": "claude-opus-4-7[1m]", "display_name": "Opus 4.7 (1M context)" },
        "workspace": { "current_dir": "/tmp", "project_dir": "/tmp" },
        "context_window": { "used_percentage": 0, "remaining_percentage": 100 },
        "rate_limits": {
          "five_hour": { "used_percentage": 0 },
          "seven_day": { "used_percentage": 0 }
        },
        "output_style": { "name": "default" }
      },
      "expect_contains": [
        "0% ctx",
        "0% 5h",
        "0% 7d",
        "\u001b[32m",
        "Opus 4.7 (1M context)",
        "○○○○○○○○○○"
      ],
      "expect_not_contains": [
        "\u001b[33m",
        "\u001b[31m",
        "ccusage not installed"
      ],
      "expect_exit_code": 0
    },
    {
      "name": "mid-green-band",
      "type": "positive",
      "description": "All three percentages sit in the green band (<50%). Expect green color codes only and half-fill dot bars.",
      "stub_ccusage_output": "",
      "stub_ccusage_exit": 0,
      "stdin_json": {
        "session_id": "eval-45pct",
        "transcript_path": "EVAL_TRANSCRIPT",
        "cwd": "/tmp",
        "model": { "id": "claude-opus-4-7[1m]", "display_name": "Opus 4.7 (1M context)" },
        "workspace": { "current_dir": "/tmp", "project_dir": "/tmp" },
        "context_window": { "used_percentage": 45, "remaining_percentage": 55 },
        "rate_limits": {
          "five_hour": { "used_percentage": 30 },
          "seven_day": { "used_percentage": 40 }
        },
        "output_style": { "name": "default" }
      },
      "expect_contains": [
        "45% ctx",
        "30% 5h",
        "40% 7d",
        "\u001b[32m"
      ],
      "expect_not_contains": [
        "\u001b[33m",
        "\u001b[31m"
      ],
      "expect_exit_code": 0
    },
    {
      "name": "yellow-band-ctx",
      "type": "positive",
      "description": "Context is in yellow band (50–74%). Expect yellow color code alongside ctx segment.",
      "stub_ccusage_output": "",
      "stub_ccusage_exit": 0,
      "stdin_json": {
        "session_id": "eval-60pct",
        "transcript_path": "EVAL_TRANSCRIPT",
        "cwd": "/tmp",
        "model": { "id": "claude-opus-4-7[1m]", "display_name": "Opus 4.7 (1M context)" },
        "workspace": { "current_dir": "/tmp", "project_dir": "/tmp" },
        "context_window": { "used_percentage": 60, "remaining_percentage": 40 },
        "rate_limits": {
          "five_hour": { "used_percentage": 30 },
          "seven_day": { "used_percentage": 40 }
        },
        "output_style": { "name": "default" }
      },
      "expect_contains": [
        "60% ctx",
        "\u001b[33m"
      ],
      "expect_exit_code": 0
    },
    {
      "name": "red-band-weekly",
      "type": "positive",
      "description": "7-day quota is in the red band (>=75%). Expect red color code surrounding the 7d segment.",
      "stub_ccusage_output": "",
      "stub_ccusage_exit": 0,
      "stdin_json": {
        "session_id": "eval-85pct",
        "transcript_path": "EVAL_TRANSCRIPT",
        "cwd": "/tmp",
        "model": { "id": "claude-opus-4-7[1m]", "display_name": "Opus 4.7 (1M context)" },
        "workspace": { "current_dir": "/tmp", "project_dir": "/tmp" },
        "context_window": { "used_percentage": 30, "remaining_percentage": 70 },
        "rate_limits": {
          "five_hour": { "used_percentage": 40 },
          "seven_day": { "used_percentage": 85 }
        },
        "output_style": { "name": "default" }
      },
      "expect_contains": [
        "30% ctx",
        "85% 7d",
        "\u001b[31m"
      ],
      "expect_exit_code": 0
    },
    {
      "name": "missing-context-window-ccusage-fallback",
      "type": "negative",
      "description": "Older Claude Code version: stdin lacks context_window; wrapper falls back to ccusage statusline regex for ctx percent. Model label still renders from stdin, rate-limit bars are skipped.",
      "stub_ccusage_output": "Opus | $0.50 session / $5.00 today / $30.00 block | 100,000 (10%)",
      "stub_ccusage_exit": 0,
      "stdin_json": {
        "session_id": "eval-legacy",
        "transcript_path": "EVAL_TRANSCRIPT",
        "cwd": "/tmp",
        "model": { "id": "claude-opus-4-7[1m]", "display_name": "Opus 4.7 (1M context)" },
        "workspace": { "current_dir": "/tmp", "project_dir": "/tmp" }
      },
      "expect_contains": [
        "10% ctx",
        "Opus 4.7 (1M context)"
      ],
      "expect_not_contains": [
        "5h",
        "7d"
      ],
      "expect_exit_code": 0
    },
    {
      "name": "malformed-stdin-safe",
      "type": "negative",
      "description": "Non-JSON stdin. Expect a quiet fallback line, not a crash or non-zero exit.",
      "stub_ccusage_exit": null,
      "raw_stdin": "this is not json",
      "expect_contains": [
        "cc-context-monitor"
      ],
      "expect_not_contains": [
        "ctx"
      ],
      "expect_exit_code": 0
    },
    {
      "name": "annotation-preserved",
      "type": "positive",
      "description": "CC_STATUSLINE_ANNOTATION is set in the environment. Expect the annotation to appear appended after the main segments, not replacing them.",
      "stub_ccusage_output": "",
      "stub_ccusage_exit": 0,
      "env": { "CC_STATUSLINE_ANNOTATION": "Remote control active" },
      "stdin_json": {
        "session_id": "eval-annotation",
        "transcript_path": "EVAL_TRANSCRIPT",
        "cwd": "/tmp",
        "model": { "id": "claude-opus-4-7[1m]", "display_name": "Opus 4.7 (1M context)" },
        "workspace": { "current_dir": "/tmp", "project_dir": "/tmp" },
        "context_window": { "used_percentage": 10, "remaining_percentage": 90 },
        "rate_limits": {
          "five_hour": { "used_percentage": 5 },
          "seven_day": { "used_percentage": 12 }
        },
        "output_style": { "name": "default" }
      },
      "expect_contains": [
        "10% ctx",
        "5% 5h",
        "12% 7d",
        "Remote control active"
      ],
      "expect_exit_code": 0
    }
  ]
}
