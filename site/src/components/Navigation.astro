---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'home' },
  { href: '/samples/', label: 'samples' },
  { href: 'https://tech.bdigitalmedia.io', label: 'blog', external: true },
  { href: 'https://github.com/neurot1cal/bdigital-public', label: 'github', external: true },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-obsidian/80 border-b border-zinc-900">
  <nav class="container-inner flex items-center justify-between h-16">
    <a href="/" class="font-display font-bold text-snow no-underline tracking-tight">
      bdigital<span class="text-zinc-500">.</span>public
    </a>
    <ul class="flex items-center gap-6 text-sm">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'no-underline transition-colors',
              currentPath === link.href ? 'text-snow' : 'text-zinc-400 hover:text-snow',
            ]}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
